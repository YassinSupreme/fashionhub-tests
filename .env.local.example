# .env.local.example
# -------------------
# Copy this to .env to run tests against the local Docker app instead of GitHub Pages.
#
# Option A — Inside docker compose (automatic, no .env needed):
#   docker compose up --build
#
# Option B — App in Docker, tests on host:
#   1. Start the app container:   docker compose up fashionhub-app
#   2. Run tests on host:         BASE_URL=http://localhost:4000/fashionhub/ npm test

BASE_URL=http://localhost:4000/fashionhub/
