# FashionHub Test Environment Configuration
# Copy this file to .env and fill in values as needed.
# CLI environment variables always take PRIORITY over this file.

# ─── Option A: Provide a full base URL directly ───────────────────────────────
# This takes the highest priority over TEST_ENV below.
# BASE_URL=http://localhost:4000/fashionhub/

# ─── Option B: Use a named environment ────────────────────────────────────────
# Supported values: local | staging | production
# TEST_ENV=production

# ─── Notes ────────────────────────────────────────────────────────────────────
# If neither BASE_URL nor TEST_ENV is set, tests default to "production":
#   https://pocketaces2.github.io/fashionhub/
